<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - Admin</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <div class="dashboard-container">
    <%- include('../partials/sidebar') %>
    
    <main class="main-content">
      <header class="page-header">
        <h1><i class="fas fa-chart-line"></i> Tableau de bord</h1>
        <p>Bienvenue, <%= user.nickname %></p>
      </header>

      <% if (success && success.length > 0) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>
      <% if (error && error.length > 0) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <div class="stats-grid">
        <div class="stat-card">
          <i class="fas fa-newspaper"></i>
          <h3><%= totalPosts %></h3>
          <p>Total Posts</p>
          <span class="badge"><%= pendingPosts %> proposé</span>
        </div>

        <div class="stat-card">
          <i class="fas fa-flag"></i>
          <h3><%= totalReports %></h3>
          <p>Total Signalements</p>
          <span class="badge"><%= pendingReports %> en attente</span>
        </div>

        <div class="stat-card">
          <i class="fas fa-users"></i>
          <h3><%= totalUsers %></h3>
          <p>Total Utilisateurs</p>
        </div>
      </div>

      <div class="tables-grid">
        <section class="table-section">
          <h2><i class="fas fa-newspaper"></i> Posts Récents</h2>
          <table>
            <thead>
              <tr>
                <th>Titre</th>
                <th>Auteur</th>
                <th>Bus</th>
                <th>Statut</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% recentPosts.forEach(post => { %>
                <tr>
                  <td><%= post.title || 'Live Location' %></td>
                  <td><%= post.author.nickname %></td>
                  <td>Bus <%= post.bus.numero %></td>
                  <td><span class="badge badge-<%= post.status %>"><%= post.status %></span></td>
                  <td><%= new Date(post.createdAt).toLocaleDateString('fr-FR') %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
          <a href="/admin/posts" class="btn btn-primary">Voir tous les posts</a>
        </section>

        <section class="table-section">
          <h2><i class="fas fa-flag"></i> Signalements Récents</h2>
          <table>
            <thead>
              <tr>
                <th>Raison</th>
                <th>Reporter</th>
                <th>Statut</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% recentReports.forEach(report => { %>
                <tr>
                  <td><%= report.reason %></td>
                  <td><%= report.reporter.nickname %></td>
                  <td><span class="badge badge-<%= report.status.replace(' ', '-') %>"><%= report.status %></span></td>
                  <td><%= new Date(report.date).toLocaleDateString('fr-FR') %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
          <a href="/admin/reports" class="btn btn-primary">Voir tous les signalements</a>
        </section>
      </div>
    </main>
  </div>
</body>
</html>
